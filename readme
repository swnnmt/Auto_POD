# main đã tạo và push khung cùng các file build
# git branch dev  # tạo nhánh dev 

# start
# git checkout main     #chuyển sang nhánh main
# git pull origin main  # lấy tất cả code ở main hiện tại
# git checkout dev      # sang nhánh dev
# git merge main        # lấy code mới nhất ở main

# tạo nhánh feature
# git checkout -b feature/ten-tinh-nang   # tạo nhánh cho chức năng và chuyển sang nhánh chức năng
# git merge dev                           # lấy code mới nhất ở dev

# Code xong
# git add .
# git commit -m "Thêm tính năng A"
# git push origin feature/ten-tinh-nang

# Test ( ko cần tạo nhánh tránh rối)
# git checkout feature/ten-tinh-nang # sang nhánh tính năng
# git pull origin feature/ten-tinh-nang # lấy code ở nhánh tính năng
# Test và báo cái lại dev -> có bug -> Dev fix bug → push lại branch feature -> pull lại và test
# Done → tạo Pull Request (feature → dev) trên GitHub



# Release ( phiên bản hoàn chỉnh luôn sẵn sàng sử dụng)
# git checkout dev
# git pull origin dev  # lấy mới nhất của dev
# git checkout main
# git pull origin main # lấy mới nhất của main
# git merge dev
# git push origin main